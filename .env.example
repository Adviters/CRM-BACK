NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://petshop:petshop@localhost:5432/petshop?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12

SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Comma-separated list of allowed CORS origins (empty = CORS disabled)
CORS_ORIGINS=http://localhost:5173

# Seed admin (used by prisma seed)
ADMIN_EMAIL=admin@petshop.local
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
